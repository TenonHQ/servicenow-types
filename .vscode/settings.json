{
  "files.eol": "\n",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": [
    "source.organizeImports",
    "source.fixAll",
    "source.fixAll.eslint"
  ],
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.detectIndentation": false,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "search.useIgnoreFiles": false,
  "search.exclude": {
    "**/node_modules": true
  },
  "stylelint.validate": ["css", "scss"],
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "now.instance.user.name": "",
  "now.instance.host.url": "",
  "now.instance.OAuth.client.id": "",
  "now.instance.user.password": "",
  "now.instance.OAuth.client.secret": "",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[js]": {
    "editor.tabSize": 4
  },
  "[ts]": {
    "editor.tabSize": 4
  },
  "[css]": {
    "editor.tabSize": 2
  },
  "[scss]": {
    "editor.tabSize": 2
  },
  "window.title": "ServiceNow Types - ${activeEditorShort}${separator}${rootName}"
}
